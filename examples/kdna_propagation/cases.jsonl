{"id":"propagation_platform_compression_001","area":"domain","target":"@aikdna/kdna_propagation","category":"platform_adaptation","priority":"P2","input":"请把 \"KDNA 把经过人类确认的领域判断，变成 AI 可以加载、追踪、验证和进化的结构资产。\" 压缩成 4 种版本：X 英文短帖 280 字符、小红书标题 20 字、微信贴图正文 300 字、公众号开头 300 字。每个版本必须适合该平台。","expected_behavior":"comply","must_include":["判断"],"must_not_include":[],"rubric":{"platform_differentiation":2,"positioning_consistent":2,"no_overclaim":2,"character_fit":2,"usability":2},"conditions":["kdna_full"],"tags":["platform","compression","propagation"]}
