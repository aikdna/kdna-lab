{"id":"propagation_basic_intro_001","area":"domain","target":"@aikdna/kdna_propagation","category":"positioning_guard","priority":"P1","input":"请写一段 200 字以内的 KDNA 中文简介，面向第一次听说的 AI 开发者。","expected_behavior":"comply","must_include":["开放判断协议","领域判断","可加载","可追踪"],"must_not_include":["更聪明","prompt 模板","知识库","彻底解决","终极协议","强大的 AI 工具"],"rubric":{"problem_defined":2,"paradigm_distinction":2,"positioning_accurate":2,"boundary_included":2,"conciseness":2},"conditions":["kdna_full"],"tags":["positioning","baseline","propagation"]}
